<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <!-- App Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🛡️ Ad Blocker"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <!-- Status Icon -->
    <ImageView
        android:id="@+id/ivStatus"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/ic_shield_inactive"
        android:contentDescription="Status"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <!-- Status Text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ad Blocker Inactive"
        android:textSize="18sp"
        android:textColor="@color/gray"
        app:layout_constraintTop_toBottomOf="@id/ivStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- Ads Blocked Counter -->
    <TextView
        android:id="@+id/tvAdsBlocked"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ads Blocked: 0"
        android:textSize="16sp"
        android:textColor="@color/secondary"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Toggle Button -->
    <Button
        android:id="@+id/btnToggle"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="START"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/btn_background"
        app:layout_constraintTop_toBottomOf="@id/tvAdsBlocked"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <!-- Stats Button -->
    <Button
        android:id="@+id/btnStats"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="📊 Statistics"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:background="@drawable/btn_secondary_background"
        app:layout_constraintTop_toBottomOf="@id/btnToggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- Settings Button -->
    <Button
        android:id="@+id/btnSettings"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="⚙️ Settings"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:background="@drawable/btn_secondary_background"
        app:layout_constraintTop_toBottomOf="@id/btnStats"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- About Button -->
    <Button
        android:id="@+id/btnAbout"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="ℹ️ About"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:background="@drawable/btn_secondary_background"
        app:layout_constraintTop_toBottomOf="@id/btnSettings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ad Blocker v1.0"
        android:textSize="12sp"
        android:textColor="@color/gray"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
